{
  "name": "liga-frontend",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.6.3",

  "scripts": {
    "ng": "ng",
    "start": "serve -s dist/liga-frontend",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "dev": "ng serve",
    "test": "echo \"No Angular tests configured\""
  },

  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },

  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "cypress": "^15.13.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "serve": "^14.2.0"
  },

  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  }
}